<%- include('../partials/header') %>
<div class="cyber-container" style="flex-direction: column; justify-content: center; align-items: center;">
    <div class="cyber-grid-bg"></div>
    
    <!-- Confetti container -->
    <div id="cyber-confetti-container"></div>

    <div class="cyber-success-card glass-panel" style="animation: cardEntry 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;">
        
        <div class="success-icon-container">
            <div class="cyber-icon pdf-icon final-pdf-icon" style="opacity: 1; animation: none;">PDF</div>
            <div class="success-ring"></div>
        </div>
        
        <h1 class="success-heading">Your PDF is ready!</h1>
        
        <div class="file-details">
            <span class="file-name"><%= file %></span>
            <span class="file-size">~1.2 MB</span>
        </div>
        
        <a href="/uploads/<%= file %>" download="<%= file %>" class="cyber-btn cyber-glitch-btn success-btn" id="download-btn">
            <span class="btn-text">DOWNLOAD PDF</span>
        </a>
        
        <a href="/home" class="cyber-link upload-more-link">
            &larr; Upload more files
        </a>
    </div>

    <!-- Developer Socials -->
    <div class="developer-socials"
        style="display: flex; justify-content: center; align-items: center; gap: 1.5rem; margin: 2rem auto 0 auto; position: relative; z-index: 10; font-family: inherit;">
        <span style="font-size: 0.9rem; letter-spacing: 2px; color: rgba(255,255,255,0.6); font-weight: bold; text-transform: uppercase;">Developer: Shreyansh</span>
        <div style="display: flex; gap: 1.2rem; align-items: center;">
            <a href="https://www.linkedin.com/in/shreyansh-nechaniya-4b5771375/" target="_blank"
                style="color: var(--cyber-accent); display: flex; align-items: center; justify-content: center; transition: transform 0.2s ease, filter 0.2s ease; text-decoration: none;"
                onmouseover="this.style.transform='translateY(-3px)'; this.style.filter='drop-shadow(0 0 8px var(--cyber-accent))'"
                onmouseout="this.style.transform='translateY(0)'; this.style.filter='none'"
                title="LinkedIn">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                </svg>
            </a>
            <a href="https://github.com/Shreyansh-069" target="_blank"
                style="color: var(--cyber-accent); display: flex; align-items: center; justify-content: center; transition: transform 0.2s ease, filter 0.2s ease; text-decoration: none;"
                onmouseover="this.style.transform='translateY(-3px)'; this.style.filter='drop-shadow(0 0 8px var(--cyber-accent))'"
                onmouseout="this.style.transform='translateY(0)'; this.style.filter='none'"
                title="GitHub">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
                </svg>
            </a>
        </div>
    </div>
</div>


<script>
    // Confetti-style pixel animation on success
    function createConfetti() {
        const container = document.getElementById('cyber-confetti-container');
        const colors = ['#00f0ff', '#00ff88', '#8a2be2', '#ff003c'];
        
        for(let i=0; i < 70; i++) {
            const confetti = document.createElement('div');
            confetti.classList.add('cyber-confetti-pixel');
            
            // Random properties
            const color = colors[Math.floor(Math.random() * colors.length)];
            const left = Math.random() * 100;
            const top = -10 + Math.random() * -20;
            const size = Math.random() * 8 + 6;
            const duration = Math.random() * 2 + 2.5;
            const delay = Math.random() * 0.5;
            
            confetti.style.backgroundColor = color;
            confetti.style.left = left + 'vw';
            confetti.style.top = top + 'vh';
            confetti.style.width = size + 'px';
            confetti.style.height = size + 'px';
            confetti.style.animation = `confettiFall ${duration}s ${delay}s linear forwards`;
            confetti.style.boxShadow = `0 0 8px ${color}`;
            
            container.appendChild(confetti);
        }
    }
    
    // Trigger confetti rapidly upon document finish
    window.addEventListener('DOMContentLoaded', createConfetti);
</script>
</body>
</html>
