<%- include('../partials/header') %>
    <div class="cyber-container" style="flex-direction: column; justify-content: flex-start;">
        <div class="cyber-grid-bg"></div>
        <div class="pixel-noise-bg"></div>

        <!-- Navbar -->
        <nav class="cyber-navbar">
            <div class="cyber-logo" data-text="Xshift" style="font-size: 1.5rem; letter-spacing: 1px;">Xshift</div>
            <div class="cyber-nav-links">
                <a href="/home" class="cyber-link active">Home</a>
                <button id="logout-btn" class="cyber-btn-outline">Logout</button>
            </div>
        </nav>

        <!-- Hero Section -->
        <div class="cyber-hero">
            <div class="hero-content">
                <h1 class="hero-heading">Upload your images<span class="blink"
                        style="color: var(--cyber-accent);">_</span></h1>
                <p class="cyber-tagline" style="font-size: 1.1rem; margin-bottom: 2rem;">JPEG or PNG &rarr; Convert
                    instantly to PDF</p>

                <form action="/convert" method="POST" enctype="multipart/form-data" id="upload-form"
                    class="cyber-upload-form">

                    <input type="file" name="image" id="file-upload" class="hidden-input"
                        accept="image/png, image/jpeg">

                    <button type="button" class="cyber-btn cyber-glitch-btn" id="trigger-upload"
                        style="margin-top: 1rem; padding: 16px 35px; font-size: 1.1rem; width: auto;">
                        <span class="btn-text">UPLOAD</span>
                    </button>
                    <div id="file-name-display" class="file-chosen-text"></div>

                    <button type="submit" id="submit-upload" class="cyber-btn-outline"
                        style="display: none; margin-top: 1.5rem; padding: 12px 25px; border-color: var(--cyber-accent); color: var(--cyber-accent);">
                        CONVERT TO PDF
                    </button>
                </form>
            </div>

            <!-- Animated Illustration -->
            <div class="cyber-illustration">
                <div class="floating-file jpg-file"><span class="inner">JPG</span></div>
                <div class="arrow-anim">&rarr;</div>
                <div class="floating-file pdf-file"><span class="inner">PDF</span></div>
            </div>
        </div>

        <!-- Developer Socials -->
        <div class="developer-socials"
            style="display: flex; justify-content: center; align-items: center; gap: 1.5rem; margin: 4rem auto 2rem auto; position: relative; z-index: 10; font-family: inherit;">
            <span style="font-size: 0.9rem; letter-spacing: 2px; color: rgba(255,255,255,0.6); font-weight: bold; text-transform: uppercase;">Developer: Shreyansh</span>
            <div style="display: flex; gap: 1.2rem; align-items: center;">
                <a href="https://www.linkedin.com/in/shreyansh-nechaniya-4b5771375/" target="_blank"
                    style="color: var(--cyber-accent); display: flex; align-items: center; justify-content: center; transition: transform 0.2s ease, filter 0.2s ease; text-decoration: none;"
                    onmouseover="this.style.transform='translateY(-3px)'; this.style.filter='drop-shadow(0 0 8px var(--cyber-accent))'"
                    onmouseout="this.style.transform='translateY(0)'; this.style.filter='none'"
                    title="LinkedIn">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
                        <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                    </svg>
                </a>
                <a href="https://github.com/Shreyansh-069" target="_blank"
                    style="color: var(--cyber-accent); display: flex; align-items: center; justify-content: center; transition: transform 0.2s ease, filter 0.2s ease; text-decoration: none;"
                    onmouseover="this.style.transform='translateY(-3px)'; this.style.filter='drop-shadow(0 0 8px var(--cyber-accent))'"
                    onmouseout="this.style.transform='translateY(0)'; this.style.filter='none'"
                    title="GitHub">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
                    </svg>
                </a>
            </div>
        </div>

    </div>

    <script>
        const fileInput = document.getElementById('file-upload');
        const triggerBtn = document.getElementById('trigger-upload');
        const displayTxt = document.getElementById('file-name-display');
        const submitBtn = document.getElementById('submit-upload');
        const jpgFile = document.querySelector('.jpg-file .inner');

        triggerBtn.addEventListener('click', () => {
            fileInput.click();
        });

        fileInput.addEventListener('change', function () {
            if (this.files && this.files.length > 0) {
                displayTxt.innerText = '> FILE_ACQUIRED: ' + this.files[0].name;
                displayTxt.style.color = 'var(--cyber-accent)';
                submitBtn.style.display = 'inline-block';
                triggerBtn.style.display = 'none';

                const ext = this.files[0].name.split('.').pop().toUpperCase();
                jpgFile.innerText = ext;
                document.querySelector('.jpg-file').classList.add('glitch-file');
            }
        });

        submitBtn.addEventListener('click', () => {
            submitBtn.innerText = 'CONVERTING...';
            submitBtn.style.pointerEvents = 'none';
            submitBtn.style.background = 'rgba(0, 240, 255, 0.2)';
        });

        document.getElementById('logout-btn').addEventListener('click', async () => {
            try {
                await fetch('/api/logout', { method: 'POST' });
                window.location.href = '/login';
            } catch (e) {
                console.error('Logout failed');
            }
        });
    </script>
    </body>

    </html>